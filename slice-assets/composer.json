{
  "name": "fullsmack/slice-assets",
  "description": "Register and bundle frontend assets (JS/TS/CSS) from Laravel Slice modules via Vite",
  "homepage": "https://github.com/fullsmack/slice-assets",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "nicolaibaaring"
    }
  ],
  "require": {
    "php": "^8.2|^8.3|^8.4",
    "illuminate/contracts": "^10.0 || ^11.0 || ^12.0",
    "illuminate/support": "^10.0 || ^11.0 || ^12.0",
    "fullsmack/laravel-slice": "dev-feature/nested-slices"
  },
  "require-dev": {
    "orchestra/testbench": "^9.0 || ^10.0",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "FullSmack\\SliceAssets\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "FullSmack\\SliceAssets\\SliceAssetsServiceProvider"
      ]
    }
  }
}
